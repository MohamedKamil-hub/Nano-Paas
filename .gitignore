# Archivos de claves privadas y certificados
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx
*.priv
*.p8
id_rsa*
id_ed25519*
*.pem

# Datos de Nginx Proxy Manager (incluye claves, DB, etc.)
data/npm/
data/letsencrypt/

# Logs
logs/
*.log

# Bases de datos SQLite
*.sqlite
*.sqlite3
*.db

# Archivos de entorno y secretos
.env
.env.local
.env.*.local
*.secret
secrets/

# Archivos comprimidos y binarios
*.deb
*.exe
*.dll
*.so
*.dylib
*.bin

# Directorios de respaldo
*-backup-*/
backup/
*.bak

# Archivos temporales del sistema
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Directorios de dependencias (si usas alguna)
node_modules/
vendor/
__pycache__/
*.pyc

# Archivos de configuración local que no deben compartirse
config/ssh/sshd_config   # (si contiene rutas o puertos personalizados)
config/docker/daemon.json   # (no el .example)

# Ejecutables compilados
pulse/nebula-pulse
*.exe

# Archivos de ejemplo que no deben ser ejecutables
*.example
